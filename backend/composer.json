{
    "name": "systemloan/backend",
    "description": "SystemLoan API — PHP 8.3 REST",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "firebase/php-jwt": "^6.0",
        "vlucas/phpdotenv": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "App\\Controllers\\": "controllers/",
            "App\\Models\\": "models/",
            "App\\Middleware\\": "middleware/",
            "App\\Helpers\\": "helpers/"
        },
        "classmap": [
            "config/database.php"
        ]
    },
    "config": {
        "audit": {
            "abandoned": "ignore",
            "block-insecure": false
        }
    }
}
